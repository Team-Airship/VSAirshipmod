{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"-c",
				"Debug",
				"${workspaceFolder}\\VSAirshipmod\\VSAirshipmod\\VSAirshipmod.csproj"
			],
			"problemMatcher": "$msCompile",
			"group": "build"
		},        
		{
            "label": "package",
            "command": "dotnet",
            "type": "process",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/VSAirshipmod/CakeBuild/CakeBuild.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
		{
			"label": "build (Cake)",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"-c",
				"Debug",
				"${workspaceFolder}/VSAirshipmod/CakeBuild/CakeBuild.csproj"
			],
			"problemMatcher": "$msCompile",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}